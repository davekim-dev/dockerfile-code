cat > Dockerfile << 'EOF'
FROM nginx:alpine
LABEL maintainer="my-custom-nginx"
LABEL description="커스텀 정적 콘텐츠를 서빙하는 NGINX 이미지"
COPY nginx/default.conf /etc/nginx/conf.d/default.conf
COPY html/ /usr/share/nginx/html/
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
EOF


